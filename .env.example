# Supabase (required)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Stripe (optional — needed for checkout)
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_or_test_key

# Panda Video (optional — dev proxy only)
PANDA_API_KEY=panda-your-api-key

# Sentry (build-time — for source map upload)
SENTRY_AUTH_TOKEN=sntryu_your_token
